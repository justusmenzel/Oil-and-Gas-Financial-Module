/* ══════════════════════════════════════════════════════════════
   SLIDER COMPONENT
   ══════════════════════════════════════════════════════════════ */
function Slider({ label, value, onChange, min, max, step, prefix, suffix }) {
  const num = step < 1
    ? value.toFixed(step < 0.1 ? 2 : 1)
    : value.toLocaleString("en-US", { maximumFractionDigits: 0 });
  return (
    <div style={{ marginBottom: 20 }}>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 6 }}>
        <span style={{ fontSize: 13, color: C.text, fontWeight: 600 }}>{label}</span>
        <span style={{ fontSize: 16, fontWeight: 800, color: C.gold, fontVariantNumeric: "tabular-nums" }}>
          {prefix || ""}{num}{suffix || ""}
        </span>
      </div>
      <input type="range" min={min} max={max} step={step} value={value}
        onChange={e => onChange(parseFloat(e.target.value))}
        style={{ width: "100%", accentColor: C.gold, height: 6, cursor: "pointer" }} />
    </div>
  );
}

/* ══════════════════════════════════════════════════════════════
   CHART: BAR
   ══════════════════════════════════════════════════════════════ */
function BarChart({ data, color, labelFn, height = 260 }) {
  const mx = Math.max(...data.map(d => Math.abs(d.v)), 1);
  return (
    <div>
      <div style={{ display: "flex", alignItems: "flex-end", gap: 5, height, borderBottom: `2px solid ${C.bgBorder}`, padding: "0 2px" }}>
        {data.map((d, i) => {
          const h = Math.abs(d.v) / mx * (height - 50);
          return (
            <div key={i} style={{ flex: 1, display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "flex-end", height: "100%" }}>
              <div style={{ fontSize: 11, color: C.gold, fontWeight: 700, marginBottom: 4, fontVariantNumeric: "tabular-nums" }}>
                {labelFn?.(d) || ""}
              </div>
              <div style={{
                width: "72%", maxWidth: 32, height: Math.max(3, h), borderRadius: "4px 4px 0 0",
                background: typeof color === "function" ? color(d) : color || C.gold,
              }} />
            </div>
          );
        })}
      </div>
      <div style={{ display: "flex", gap: 5, padding: "0 2px" }}>
        {data.map((d, i) => (
          <div key={i} style={{ flex: 1, textAlign: "center", fontSize: 11, color: C.label, paddingTop: 6, fontWeight: 600 }}>{d.label}</div>
        ))}
      </div>
    </div>
  );
}

/* ══════════════════════════════════════════════════════════════
   CHART: LINE
   ══════════════════════════════════════════════════════════════ */
function LineChart({ series, height = 260, xLabels, hLine, hLineLabel }) {
  const allVals = [...series.flatMap(s => s.data), hLine || 0];
  const mx = Math.max(...allVals) * 1.15;
  const mn = Math.min(0, ...allVals);
  const range = mx - mn || 1;
  const w = xLabels.length * 55;
  const pad = 28;
  const yPos = v => height - pad - ((v - mn) / range) * (height - pad * 2);

  return (
    <svg viewBox={`0 0 ${w} ${height}`} style={{ width: "100%", height }}>
      <defs>
        {series.map((s, si) => (
          <linearGradient key={si} id={`grad${si}`} x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stopColor={s.color} stopOpacity=".18" />
            <stop offset="100%" stopColor={s.color} stopOpacity=".01" />
          </linearGradient>
        ))}
      </defs>
      <line x1={pad} y1={height - pad} x2={w - pad} y2={height - pad} stroke={C.bgBorder} strokeWidth="1" />
      {hLine != null && (
        <>
          <line x1={pad} y1={yPos(hLine)} x2={w - pad} y2={yPos(hLine)} stroke={C.red} strokeWidth="2" strokeDasharray="6 4" opacity=".6" />
          <text x={pad + 6} y={yPos(hLine) - 8} fill={C.red} fontSize="11" fontFamily="DM Sans" fontWeight="600" opacity=".8">{hLineLabel || ""}</text>
        </>
      )}
      {series.map((s, si) => {
        const pts = s.data.map((v, i) => ({
          x: (i / (xLabels.length - 1)) * (w - pad * 2) + pad,
          y: yPos(v),
        }));
        const path = pts.map((p, i) => `${i === 0 ? "M" : "L"}${p.x},${p.y}`).join(" ");
        if (si === 0) {
          const area = path + ` L${pts[pts.length - 1].x},${height - pad} L${pts[0].x},${height - pad} Z`;
          return (
            <g key={si}>
              <path d={area} fill={`url(#grad${si})`} />
              <path d={path} fill="none" stroke={s.color} strokeWidth="3" strokeLinejoin="round" />
              {pts.map((p, i) => <circle key={i} cx={p.x} cy={p.y} r={5} fill={C.bg} stroke={s.color} strokeWidth="2.5" />)}
            </g>
          );
        }
        return (
          <g key={si}>
            <path d={path} fill="none" stroke={s.color} strokeWidth="2.5" strokeLinejoin="round" strokeDasharray={si > 1 ? "6 3" : ""} />
            {pts.map((p, i) => <circle key={i} cx={p.x} cy={p.y} r={4} fill={C.bg} stroke={s.color} strokeWidth="2" />)}
          </g>
        );
      })}
      {xLabels.map((l, i) => {
        const x = (i / (xLabels.length - 1)) * (w - pad * 2) + pad;
        return <text key={i} x={x} y={height - 6} textAnchor="middle" fill={C.label} fontSize="11" fontFamily="DM Sans" fontWeight="600">{l}</text>;
      })}
    </svg>
  );
}

/* ══════════════════════════════════════════════════════════════
