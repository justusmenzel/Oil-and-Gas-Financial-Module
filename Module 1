/* ══════════════════════════════════════════════════════════════
   UTILITIES
   ══════════════════════════════════════════════════════════════ */
function calcIRR(cfs, guess = 0.1) {
  let r = guess;
  for (let i = 0; i < 300; i++) {
    let npv = 0, dnpv = 0;
    for (let t = 0; t < cfs.length; t++) {
      const p = Math.pow(1 + r, t);
      npv += cfs[t] / p;
      dnpv -= t * cfs[t] / (p * (1 + r));
    }
    if (Math.abs(dnpv) < 1e-12) break;
    const nr = r - npv / dnpv;
    if (Math.abs(nr - r) < 1e-9) return nr;
    r = nr;
    if (r < -0.99) r = -0.5;
    if (r > 10) r = 5;
  }
  return r;
}

// Number formatters
const fDol2 = (v) => v.toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const fDol0 = (v) => "$" + Math.abs(v).toLocaleString("en-US", { maximumFractionDigits: 0 });
const fMM = (v) => {
  const s = v < 0 ? "-" : "";
  const a = Math.abs(v);
  return s + "$" + (a / 1000).toLocaleString("en-US", { minimumFractionDigits: 1, maximumFractionDigits: 1 }) + "MM";
};
