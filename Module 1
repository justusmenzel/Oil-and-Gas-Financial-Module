function StackedBar({ data, keys, colors, labels, height = 260 }) {
  const mx = Math.max(...data.map(d => keys.reduce((s, k) => s + Math.abs(d[k] || 0), 0)), 1);
  return (
    <div>
      <div style={{ display: "flex", alignItems: "flex-end", gap: 5, height, borderBottom: `2px solid ${C.bgBorder}`, padding: "0 2px" }}>
        {data.map((d, i) => (
          <div key={i} style={{ flex: 1, display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "flex-end", height: "100%" }}>
            {keys.map((k, ki) => {
              const h = Math.abs(d[k] || 0) / mx * (height - 30);
              return <div key={ki} style={{ width: "72%", maxWidth: 32, height: Math.max(0, h), background: colors[ki] }} />;
            })}
          </div>
        ))}
      </div>
      <div style={{ display: "flex", gap: 5, padding: "0 2px" }}>
        {data.map((d, i) => <div key={i} style={{ flex: 1, textAlign: "center", fontSize: 11, color: C.label, paddingTop: 6, fontWeight: 600 }}>{d.label}</div>)}
      </div>
      <div style={{ display: "flex", gap: 24, marginTop: 14, justifyContent: "center", flexWrap: "wrap" }}>
        {keys.map((k, i) => (
          <div key={i} style={{ display: "flex", alignItems: "center", gap: 6 }}>
